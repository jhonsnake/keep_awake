msgid "Keep Awake"
msgstr "Не засыпать"

msgid "Active: the computer will not sleep or start the screensaver"
msgstr "Включено: компьютер не перейдёт в спящий режим и не запустит заставку"

msgid "Inactive: normal power behavior"
msgstr "Выключено: обычное управление питанием"

msgid "Active — the computer won't sleep"
msgstr "Включено — компьютер не перейдёт в спящий режим"

msgid "Inactive — normal power"
msgstr "Выключено — обычное питание"
