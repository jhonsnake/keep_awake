msgid "Keep Awake"
msgstr "Mantieni attivo"

msgid "Active: the computer will not sleep or start the screensaver"
msgstr "Attivo: il computer non andrà in sospensione né attiverà il salvaschermo"

msgid "Inactive: normal power behavior"
msgstr "Inattivo: comportamento energetico normale"

msgid "Active — the computer won't sleep"
msgstr "Attivo — il computer non andrà in sospensione"

msgid "Inactive — normal power"
msgstr "Inattivo — energia normale"
