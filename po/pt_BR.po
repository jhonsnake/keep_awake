msgid "Inactive: normal power behavior"
msgstr "Inativo: comportamento de energia normal"

msgid "Active — the computer won't sleep"
msgstr "Ativo — o computador não será suspenso"

msgid "Inactive — normal power"
msgstr "Inativo — energia normal"
