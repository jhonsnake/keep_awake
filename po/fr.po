msgid "Keep Awake"
msgstr "Maintenir éveillé"

msgid "Active: the computer will not sleep or start the screensaver"
msgstr "Actif : l'ordinateur ne se mettra pas en veille et ne lancera pas l'économiseur d'écran"

msgid "Inactive: normal power behavior"
msgstr "Inactif : comportement d'alimentation normal"

msgid "Active — the computer won't sleep"
msgstr "Actif — l'ordinateur ne se mettra pas en veille"

msgid "Inactive — normal power"
msgstr "Inactif — alimentation normale"
